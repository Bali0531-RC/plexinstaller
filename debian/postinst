#!/bin/bash
# postinst — runs after package installation
set -e

INSTALL_DIR="/opt/plexinstaller"
BIN_DIR="/usr/local/bin"

# Create symlinks for CLI commands
ln -sf "${INSTALL_DIR}/installer.py" "${BIN_DIR}/plexinstaller"
ln -sf "${INSTALL_DIR}/plex_cli.py" "${BIN_DIR}/plex"

# Make entry points executable
chmod +x "${INSTALL_DIR}/installer.py"
chmod +x "${INSTALL_DIR}/plex_cli.py"

echo "PlexInstaller installed successfully."
echo "Run 'sudo plexinstaller' to start the installer."
echo "Run 'plex --help' for the CLI management tool."
